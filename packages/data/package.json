{
  "name": "@pinyin-pro/data",
  "version": "1.3.1",
  "description": "The data directory for pinyin-pro",
  "scripts": {
    "build": "tsc && vite build",
    "validate": "node scripts/validate.js",
    "generate:modern": "node scripts/handle-modern-dict.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zh-lx/pinyin-pro.git",
    "directory": "packages/data"
  },
  "exports": {
    "./*.json": "./json/*.json",
    "./*": {
      "import": {
        "types": "./types/*.d.ts",
        "default": "./dist/*.mjs"
      },
      "require": {
        "types": "./types/*.d.ts",
        "default": "./dist/*.js"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "json",
    "types"
  ],
  "keywords": [],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/zh-lx/pinyin-pro/issues"
  },
  "homepage": "https://github.com/zh-lx/pinyin-pro/tree/main/packages/data#readme",
  "devDependencies": {
    "node-html-parser": "^6.1.13",
    "typescript": "^5.5.4",
    "vite": "^5.4.0"
  }
}
